From 67eb4a3db3b817ce37a3b6d42fea2ca320dfd60b Mon Sep 17 00:00:00 2001
From: juanmacasado <27734146+juanmacasado@users.noreply.github.com>
Date: Sat, 20 Jun 2026 18:00:12 +0200
Subject: [PATCH] oplus: livedisplay: add Wide AMOLED Gamut display mode

Expose Wide AMOLED Gamut as a fifth native LiveDisplay profile.

The new profile uses QDCM display mode 2 (advance_native) and
Oplus seed 3 while preserving the existing four profiles.

Implemented and validated on the OnePlus 7 (guacamoleb).
---
 aidl/livedisplay/DisplayModes.cpp | 1 +
 1 file changed, 1 insertion(+)

diff --git a/aidl/livedisplay/DisplayModes.cpp b/aidl/livedisplay/DisplayModes.cpp
index b947db6..2a7b27b 100644
--- a/aidl/livedisplay/DisplayModes.cpp
+++ b/aidl/livedisplay/DisplayModes.cpp
@@ -26,6 +26,7 @@ const std::map<int32_t, DisplayModes::ModeInfo> DisplayModes::kModeMap = {
         {1, {"Natural", 1, 1}},
         {2, {"Cinematic", 0, 1}},
         {3, {"Brilliant", 4, 0}},
+        {4, {"Wide AMOLED Gamut", 2, 3}},
 };
 
 DisplayModes::DisplayModes(std::shared_ptr<sdm::SDMController> controller)
